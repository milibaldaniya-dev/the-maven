# Copy to `.env.local` (recommended for Next.js) or `.env` and fill in values.
# Never commit real secrets.

# Public site URL (metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin panel login (required in production — change from default)
ADMIN_PASSWORD=change-me

# Secret for signing admin session JWT (use a long random string in production)
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# MongoDB connection string (required for bookings storage)
MONGODB_URI=mongodb://127.0.0.1:27017/the-maven
# Optional: if your URI doesn't include db name
# MONGODB_DB=the-maven

# Optional: custom Next.js output directory
# DIST_DIR=.next
